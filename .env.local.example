# Copy this file to .env.local and fill in your values.
#
# 1. Create an internal integration at https://www.notion.so/my-integrations
#    and copy its "Internal Integration Secret" here.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Share BOTH databases with the integration:
#    open each DB in Notion -> ••• menu -> Connections -> add your integration.
#
# 3. Paste each database's ID below. To get it, open the database as a full page
#    and copy the 32-char id from the URL:
#    https://www.notion.so/<workspace>/<THIS_IS_THE_DB_ID>?v=...
NOTION_EXERCISES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_MUSCLES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
